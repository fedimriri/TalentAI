@using TalentAI.Models
@model Job
@{
    ViewData["Title"] = Model.Title + " - Applications";
    var applications = ViewBag.Applicants as List<JobApplication> ?? new List<JobApplication>();
    var matchScores = ViewBag.MatchScores as Dictionary<string, MatchingResult> ?? new Dictionary<string, MatchingResult>();
}

<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
    <div>
        <a href="/hr" style="color: var(--text-muted); text-decoration: none; font-size: 0.85rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
            &larr; Back to Jobs Feed
        </a>
        <h2 style="margin: 0; margin-bottom: 0.5rem; font-size: 2rem;">@Model.Title</h2>
        <div style="color: var(--text-muted); display: flex; gap: 1rem;">
            <span>Deadline: @Model.Deadline.ToString("MMM dd, yyyy")</span>
            <span>&bull;</span>
            <span>Posted: @Model.CreatedAt.ToString("MMM dd, yyyy")</span>
        </div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
    
    <!-- Applications Panel -->
    <div>
        <h3 style="margin-top: 0; font-size: 1.25rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 1rem;">Candidate Applications (@applications.Count)</h3>
        
        @if (applications.Count == 0)
        {
            <div style="padding: 2rem; text-align: center; color: var(--text-muted); background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);">
                No candidates have applied to this role yet.
            </div>
        }
        else
        {
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="text-align: left; color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border);">
                            <th style="padding: 0.65rem 0.75rem;">Candidate</th>
                            <th style="padding: 0.65rem 0.5rem; text-align: center;">ATS Score</th>
                            <th style="padding: 0.65rem 0.5rem; text-align: center;">Skills</th>
                            <th style="padding: 0.65rem 0.5rem; text-align: center;">Exp.</th>
                            <th style="padding: 0.65rem 0.5rem; text-align: center;">Edu.</th>
                            <th style="padding: 0.65rem 0.75rem;">Applied</th>
                            <th style="padding: 0.65rem 0.75rem; text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var applicant in applications)
                        {
                            var hasMatch = matchScores.ContainsKey(applicant.Id);
                            var m = hasMatch ? matchScores[applicant.Id] : null;
                            var total = m?.TotalScore ?? 0;
                            var skill = m?.SkillScore ?? 0;
                            var exp = m?.ExperienceScore ?? 0;
                            var edu = m?.EducationScore ?? 0;

                            string ScoreColor(double s) => s >= 75 ? "#22c55e" : s >= 50 ? "#f59e0b" : "#ef4444";
                            string ScoreBg(double s) => s >= 75 ? "rgba(34,197,94,0.12)" : s >= 50 ? "rgba(245,158,11,0.12)" : "rgba(239,68,68,0.12)";

                            <tr style="border-bottom: 1px solid var(--border); transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.02)';" onmouseout="this.style.background='transparent';">
                                <td style="padding: 0.75rem; font-weight: 500;">@applicant.CandidateEmail</td>
                                <td style="padding: 0.75rem 0.5rem; text-align: center;">
                                    @if (hasMatch)
                                    {
                                        <span style="display: inline-block; padding: 0.2rem 0.55rem; border-radius: 9999px; font-size: 0.82rem; font-weight: 600; color: @ScoreColor(total); background: @ScoreBg(total);">
                                            @total%
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color: var(--text-muted); font-size: 0.82rem;">—</span>
                                    }
                                </td>
                                <td style="padding: 0.75rem 0.5rem; text-align: center; font-size: 0.85rem; color: @(hasMatch ? ScoreColor(skill) : "var(--text-muted)");">
                                    @(hasMatch ? $"{skill}%" : "—")
                                </td>
                                <td style="padding: 0.75rem 0.5rem; text-align: center; font-size: 0.85rem; color: @(hasMatch ? ScoreColor(exp) : "var(--text-muted)");">
                                    @(hasMatch ? $"{exp}%" : "—")
                                </td>
                                <td style="padding: 0.75rem 0.5rem; text-align: center; font-size: 0.85rem; color: @(hasMatch ? ScoreColor(edu) : "var(--text-muted)");">
                                    @(hasMatch ? $"{edu}%" : "—")
                                </td>
                                <td style="padding: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">@applicant.AppliedAt.ToString("MMM dd")</td>
                                <td style="padding: 0.75rem; text-align: right;">
                                    <a href="/hr/application/@applicant.Id" style="color: var(--secondary); text-decoration: none; font-size: 0.85rem; font-weight: 500;">Review &rarr;</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Right Column (Filters & Job Details) -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- Filters Panel -->
        <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
            <h4 style="margin-top: 0; color: var(--secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">Filter Candidates</h4>
            <form method="get" action="/hr/job/@Model.Id" style="display: flex; flex-direction: column; gap: 1rem;">
                
                <div>
                    <label style="display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem;">Min. ATS Score: <span id="scoreVal">@(ViewBag.FilterMinScore ?? 0)</span>%</label>
                    <input type="range" name="minScore" min="0" max="100" value="@(ViewBag.FilterMinScore ?? 0)" 
                           oninput="document.getElementById('scoreVal').textContent = this.value"
                           style="width: 100%;" />
                </div>

                <div>
                    <label style="display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem;">Required Skill</label>
                    <input type="text" name="skill" value="@ViewBag.FilterSkill" placeholder="e.g. C#, React"
                           style="width: 100%; padding: 0.5rem; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; color: var(--text); font-size: 0.9rem;" />
                </div>

                <div>
                    <label style="display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem;">Min. Experience (Years)</label>
                    <input type="number" name="minExperience" value="@ViewBag.FilterMinExperience" step="0.5" min="0" placeholder="e.g. 2"
                           style="width: 100%; padding: 0.5rem; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; color: var(--text); font-size: 0.9rem;" />
                </div>

                <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                    <button type="submit" class="btn-primary" style="flex: 1; padding: 0.5rem;">Apply Filters</button>
                    @if (ViewBag.FilterMinScore != null || ViewBag.FilterSkill != null || ViewBag.FilterMinExperience != null)
                    {
                        <a href="/hr/job/@Model.Id" style="flex: 1; text-align: center; padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px; color: var(--text-muted); text-decoration: none; font-size: 0.85rem;">Clear</a>
                    }
                </div>
            </form>
        </div>

        <!-- Job Details Panel -->
        <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
        <h4 style="margin-top: 0; color: var(--secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">Job Description</h4>
        <p style="white-space: pre-wrap; font-size: 0.95rem; line-height: 1.6; color: var(--text-muted); margin-bottom: 2rem;">@Model.Description</p>
        
        <h4 style="margin-top: 0; color: var(--secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">Requirements</h4>
        <p style="white-space: pre-wrap; font-size: 0.95rem; line-height: 1.6; color: var(--text-muted); margin-bottom: 0;">@Model.Requirements</p>
    </div>

</div>
